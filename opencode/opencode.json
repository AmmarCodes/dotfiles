{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "npx",
        "lazy-mcp@1.2.0",
        "--config",
        "~/.config/opencode/lazy-mcp-servers.json"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@nick-vi/opencode-type-inject",
    "oh-my-opencode@latest",
    "@mohak34/opencode-notifier@latest",
    "opencode-caffeinate",
    "opencode-forge-session-title@latest"
  ],
  "tools": {
    "ls": true,
    "cat": true
  },
  "share": "disabled",
  "disabled_providers": ["zai"]
}
