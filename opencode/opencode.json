{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "npx",
        "lazy-mcp@1.2.0",
        "--config",
        "~/.config/opencode/lazy-mcp-servers.json"
      ],
      "enabled": true
    }
  },
  "plugin": ["@tarquinen/opencode-dcp@2.1.3", "oh-my-opencode@latest"],
  "tools": {
    "ls": true,
    "cat": true
  },
  "share": "disabled",
  "disabled_providers": ["zai"]
}
