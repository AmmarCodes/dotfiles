{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "lazy-mcp@2.2.3",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "tools": {
    "ls": true,
    "cat": true
  },
  "share": "disabled",
  "disabled_providers": ["zai"]
}
