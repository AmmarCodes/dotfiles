{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "lazy-mcp@2.2.3",
        "--config",
        "~/.config/lazy-mcp/servers.json"
      ]
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    }
  },
  "plugin": ["context-mode", "oh-my-openagent@latest"],
  "tools": {
    "ls": true,
    "cat": true
  },
  "share": "disabled"
}
