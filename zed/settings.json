{
  "gutter": {
    "bookmarks": false,
    "breakpoints": false
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "tabs": {
    "show_close_button": "hidden",
    "show_diagnostics": "off",
    "file_icons": false,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_name": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
  },
  "debugger": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "diagnostics": {
    "button": false,
  },
  "status_bar": {
    "active_encoding_button": "disabled",
    "show_active_file": true,
    "cursor_position_button": false,
    "active_language_button": false,
  },
  "code_lens": "on",
  "proxy": "",
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "use_system_window_tabs": true,
  "git_panel": {
    "dock": "left",
  },
  "server_url": "https://zed.dev",
  "disable_ai": false,
  "edit_predictions": {
    "allow_data_collection": "no",
    "provider": "none",
  },
  "preview_tabs": {
    "enable_preview_file_from_code_navigation": false,
    "enable_preview_from_multibuffer": false,
    "enable_preview_from_project_panel": false,
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },
  "buffer_font_size": 13.5,
  "buffer_font_family": "MonoLisa",
  "colorize_brackets": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent": {
    "dock": "right",
    "enable_feedback": false,
    "default_profile": "write",
    "play_sound_when_agent_done": "never",
    "model_parameters": [],
  },
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé",
  },
  "collaboration_panel": { "button": false },
  "base_keymap": "JetBrains",
  "show_completions_on_input": true,
  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "experimentalFeaturesEnabled": true,
        "enabledFeatures": {
          "codeActions": true,
          "codeLens": true,
          "completion": true,
          "definition": true,
          "diagnostics": true,
          "documentHighlights": true,
          "documentLink": true,
          "documentSymbols": true,
          "foldingRanges": true,
          "formatting": true,
          "hover": true,
          "inlayHint": true,
          "onTypeFormatting": true,
          "selectionRanges": true,
          "semanticHighlighting": true,
          "signatureHelp": true,
          "typeHierarchy": true,
          "workspaceSymbol": true,
        },
        "featuresConfiguration": {
          "inlayHint": {
            "enableAll": true,
          },
        },
      },
    },
    "rubocop": {
      "initialization_options": {
        "safeAutocorrect": false,
      },
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true,
          "importModuleSpecifierPreference": "shortest",
          "quotePreference": "single",
        },
        "tsserver": {
          "maxTsServerMemory": 12288,
        },
      },
    },
  },
  "languages": {
    "Markdown": {
      "colorize_brackets": true,
      "preferred_line_length": 80,
      "show_wrap_guides": true,
      "soft_wrap": "prefer_line",
    },
    "Ruby": {
      "inlay_hints": {
        "enabled": true,
      },
      "colorize_brackets": true,
      "language_servers": ["ruby-lsp", "!rubocop", "!solargraph"],
    },
    "TypeScript": {
      "colorize_brackets": true,
      "formatter": "prettier",
      "language_servers": ["typescript-language-server", "eslint"],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
    "ERB": {
      "language_servers": ["ruby-lsp"],
      "colorize_brackets": true,
      "formatter": {
        "external": {
          "command": "erb-formatter",
          "arguments": ["--stdin-filename", "{buffer_path}"],
        },
      },
    },
  },
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
    "Ruby": [
      "*.rb",
      "*.rake",
      "Rakefile",
      "Gemfile",
      "*.gemspec",
      "Guardfile",
      "Capfile",
      "*.ru",
      "*.thor",
      "*.jbuilder",
      "*.rbuild",
      ".irbrc",
      ".pryrc",
    ],
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 5000,
      "show_commit_summary": true,
    },
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show": true,
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": true,
    "indent_size": 16,
    "auto_reveal_entries": true,
    "hide_gitignore": true,
  },
  "outline_panel": {
    "dock": "left",
    "indent_size": 16,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "line_width": 1,
    "active_line_width": 2,
  },
}
