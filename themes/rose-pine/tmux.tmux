# rose-pine
base="#faf4ed"
surface="#f2e9e1"
overlay="#9893a5"
muted="#9893a5"
subtle="#9893a5"
text="#575279"
love="#b4637a"
gold="#ea9d34"
rose="#ea9d34"
pine="#286983"
foam="#d7827e"
iris="#907aa9"
highlight_low="#f2e9e1"
highlight_med="#f2e9e1"
highlight_high="#f2e9e1"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
