# catppuccin
base="#1e1e2e"
surface="#45475a"
overlay="#585b70"
muted="#585b70"
subtle="#585b70"
text="#cdd6f4"
love="#f38ba8"
gold="#f9e2af"
rose="#f9e2af"
pine="#a6e3a1"
foam="#94e2d5"
iris="#f5c2e7"
highlight_low="#45475a"
highlight_med="#45475a"
highlight_high="#45475a"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
