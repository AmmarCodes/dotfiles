# osaka-jade
base="#111c18"
surface="#23372B"
overlay="#53685B"
muted="#53685B"
subtle="#53685B"
text="#C1C497"
love="#FF5345"
gold="#459451"
rose="#459451"
pine="#549e6a"
foam="#2DD5B7"
iris="#D2689C"
highlight_low="#23372B"
highlight_med="#23372B"
highlight_high="#23372B"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
