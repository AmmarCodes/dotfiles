# hackerman
base="#0B0C16"
surface="#0B0C16"
overlay="#6a6e95"
muted="#6a6e95"
subtle="#6a6e95"
text="#ddf7ff"
love="#50f872"
gold="#50f7d4"
rose="#50f7d4"
pine="#4fe88f"
foam="#7cf8f7"
iris="#86a7df"
highlight_low="#0B0C16"
highlight_med="#0B0C16"
highlight_high="#0B0C16"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
