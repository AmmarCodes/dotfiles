# nord
base="#2e3440"
surface="#3b4252"
overlay="#4c566a"
muted="#4c566a"
subtle="#4c566a"
text="#d8dee9"
love="#bf616a"
gold="#ebcb8b"
rose="#ebcb8b"
pine="#a3be8c"
foam="#88c0d0"
iris="#b48ead"
highlight_low="#3b4252"
highlight_med="#3b4252"
highlight_high="#3b4252"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
