# ethereal
base="#060B1E"
surface="#060B1E"
overlay="#6d7db6"
muted="#6d7db6"
subtle="#6d7db6"
text="#ffcead"
love="#ED5B5A"
gold="#E9BB4F"
rose="#E9BB4F"
pine="#92a593"
foam="#a3bfd1"
iris="#c89dc1"
highlight_low="#060B1E"
highlight_med="#060B1E"
highlight_high="#060B1E"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
