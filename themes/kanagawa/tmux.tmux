# kanagawa
base="#1f1f28"
surface="#090618"
overlay="#727169"
muted="#727169"
subtle="#727169"
text="#dcd7ba"
love="#c34043"
gold="#c0a36e"
rose="#c0a36e"
pine="#76946a"
foam="#6a9589"
iris="#957fb8"
highlight_low="#090618"
highlight_med="#090618"
highlight_high="#090618"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
