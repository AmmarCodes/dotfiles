# gruvbox
base="#222526"
surface="#3c3836"
overlay="#3c3836"
muted="#665c54"
subtle="#504945"
text="#d4be98"
love="#ea6962"
gold="#e78a4e"
rose="#d8a657"
pine="#a9b665"
foam="#89b482"
iris="#d3869b"
highlight_low="#3c3836"
highlight_med="#928374"
highlight_high="#3c3836"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
