# ristretto
base="#2c2525"
surface="#72696a"
overlay="#948a8b"
muted="#948a8b"
subtle="#948a8b"
text="#e6d9db"
love="#fd6883"
gold="#f9cc6c"
rose="#f9cc6c"
pine="#adda78"
foam="#85dacc"
iris="#a8a9eb"
highlight_low="#72696a"
highlight_med="#72696a"
highlight_high="#72696a"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
