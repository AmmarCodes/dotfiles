# catppuccin-latte
base="#eff1f5"
surface="#bcc0cc"
overlay="#acb0be"
muted="#acb0be"
subtle="#acb0be"
text="#4c4f69"
love="#d20f39"
gold="#df8e1d"
rose="#df8e1d"
pine="#40a02b"
foam="#179299"
iris="#ea76cb"
highlight_low="#bcc0cc"
highlight_med="#bcc0cc"
highlight_high="#bcc0cc"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
