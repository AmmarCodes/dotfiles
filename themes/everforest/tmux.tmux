# Everforest Dark Hard
base="#272e33"
surface="#2e383c"
overlay="#374145"
muted="#7a8478"
subtle="#859289"
text="#d3c6aa"
love="#e67e80"
gold="#dbbc7f"
rose="#e69875"
pine="#83c092"
foam="#7fbbb3"
iris="#d699b6"
highlight_low="#414b50"
highlight_med="#495156"
highlight_high="#4f5b58"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
