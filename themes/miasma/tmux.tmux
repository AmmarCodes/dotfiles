# miasma
base="#222222"
surface="#000000"
overlay="#666666"
muted="#666666"
subtle="#666666"
text="#c2c2b0"
love="#685742"
gold="#b36d43"
rose="#b36d43"
pine="#5f875f"
foam="#c9a554"
iris="#bb7744"
highlight_low="#000000"
highlight_med="#000000"
highlight_high="#000000"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
