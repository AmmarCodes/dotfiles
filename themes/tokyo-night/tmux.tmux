# tokyo-night
base="#1a1b26"
surface="#32344a"
overlay="#444b6a"
muted="#444b6a"
subtle="#444b6a"
text="#a9b1d6"
love="#f7768e"
gold="#e0af68"
rose="#e0af68"
pine="#9ece6a"
foam="#449dab"
iris="#ad8ee6"
highlight_low="#32344a"
highlight_med="#32344a"
highlight_high="#32344a"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
