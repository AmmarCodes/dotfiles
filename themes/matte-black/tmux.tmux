# matte-black
base="#121212"
surface="#333333"
overlay="#8a8a8d"
muted="#8a8a8d"
subtle="#8a8a8d"
text="#bebebe"
love="#D35F5F"
gold="#b91c1c"
rose="#b91c1c"
pine="#FFC107"
foam="#bebebe"
iris="#D35F5F"
highlight_low="#333333"
highlight_med="#333333"
highlight_high="#333333"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
