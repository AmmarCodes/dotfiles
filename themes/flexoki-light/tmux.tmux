# flexoki-light
base="#FFFCF0"
surface="#100F0F"
overlay="#100F0F"
muted="#100F0F"
subtle="#100F0F"
text="#100F0F"
love="#D14D41"
gold="#D0A215"
rose="#D0A215"
pine="#879A39"
foam="#3AA99F"
iris="#CE5D97"
highlight_low="#100F0F"
highlight_med="#100F0F"
highlight_high="#100F0F"

set -g @thm_bg $base
set -g @thm_bg_tinted $base
set -g @thm_fg $text
set -g @thm_active $foam
set -g @thm_inactive $muted
set -g @thm_indicator $gold
set -g @thm_time_bg $base
set -g @thm_time_fg $text
